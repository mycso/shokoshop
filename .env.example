# Gelato print fulfillment
GELATO_API_KEY=
GELATO_STORE_ID=
GELATO_WEBHOOK_SECRET=

# Stripe payments — if unset, checkout falls back to a "demo mode" that marks orders paid immediately
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Vercel Blob storage (orders, returns, reviews, product overrides)
BLOB_READ_WRITE_TOKEN=

# Admin dashboard password (plain comparison, separate from customer accounts)
ADMIN_PASSWORD=

# Postgres database (customer accounts, password resets, 2FA, rate limiting) — Vercel Postgres or Neon
DATABASE_URL=

# Random secret used to sign customer session cookies, e.g. `openssl rand -base64 32`
SESSION_SECRET=

# Resend (transactional email: welcome, order confirmation, password reset)
RESEND_API_KEY=
EMAIL_FROM=

# Store owner inbox — receives a copy of every new order and return/refund request
ADMIN_EMAIL=
